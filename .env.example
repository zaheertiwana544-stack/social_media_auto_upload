# --- YouTube ---
# Get from https://console.cloud.google.com/apis/credentials (enable "YouTube Data API v3")
YOUTUBE_API_KEY=

# Channel to watch. Easiest: the channel's handle, e.g. @SomeChannel
YOUTUBE_CHANNEL_HANDLE=@SomeChannel

# --- Facebook ---
# Page Access Token with pages_manage_posts, pages_read_engagement, publish_video
# Get via https://developers.facebook.com/tools/explorer -> exchange for a long-lived token
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# --- Behavior ---
# How often to check for new videos, in minutes
POLL_INTERVAL_MINUTES=15

# Optional: path to a cookies.txt exported from a logged-in YouTube browser session.
# Only needed when running from a cloud/data-center IP (e.g. GitHub Actions), where
# YouTube often blocks anonymous downloads with a bot-check. Leave blank for local runs.
YTDLP_COOKIES_FILE=
